# --- DATABASE CONFIG ---
POSTGRES_DB=meal_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# --- API CONFIG ---
JWT_SECRET=your_secure_jwt_secret_here
# DATABASE_URL is constructed automatically in docker-compose.prod.yml
# but if you need it elsewhere:
# DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/meal_management?schema=public

# --- WEB CONFIG ---
# This must be the public domain of your API (e.g., https://api.yourdomain.com)
# OR if using Nginx reverse proxy on the same domain: https://yourdomain.com/api
NEXT_PUBLIC_API_URL=https://your-domain.com/api
