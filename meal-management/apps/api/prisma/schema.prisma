generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique @db.VarChar(50)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Position {
  id        String     @id @default(cuid())
  name      String     @unique @db.VarChar(50)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id            String         @id @default(cuid())
  employeeCode  String         @unique @db.VarChar(6)
  fullName      String         @db.VarChar(50)
  email         String?        @unique @db.VarChar(100)
  phoneNumber   String?        @db.VarChar(20)
  departmentId  String
  positionId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  account       Account?
  checkins      CheckinLog[]
  department    Department     @relation(fields: [departmentId], references: [id])
  position      Position       @relation(fields: [positionId], references: [id])
  reviews       MealReview[]
  registrations Registration[]
  createdGuests Guest[]        @relation("GuestCreator")
  createdDirectories GuestDirectory[] @relation("GuestDirectoryCreator")
}

model Account {
  id                  String    @id @default(cuid())
  employeeId          String    @unique
  passwordHash        String
  secretCode          String    @db.VarChar(50)
  role                Role      @default(EMPLOYEE)
  isActive            Boolean   @default(true)
  lastLogin           DateTime?
  passwordChangedAt   DateTime?
  secretCodeChangedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  employee            Employee  @relation(fields: [employeeId], references: [id])
}

model MealEvent {
  id            String         @id @default(cuid())
  mealDate      DateTime       @db.Date
  mealType      MealType
  status        MealStatus     @default(DRAFT)
  qrToken       String?        @unique
  qrGeneratedAt DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  checkins      CheckinLog[]
  guests        Guest[]
  ingredients   Ingredient[]
  reviews       MealReview[]
  menuItems     MenuItem[]
  registrations Registration[]

  @@unique([mealDate, mealType])
}

model Registration {
  id          String        @id @default(cuid())
  mealEventId String
  employeeId  String
  locationId  String?
  isCancelled Boolean       @default(false)
  cancelledBy String?
  cancelledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id])
  mealEvent   MealEvent     @relation(fields: [mealEventId], references: [id])
  location    MealLocation? @relation(fields: [locationId], references: [id])
  checkin     CheckinLog?

  @@unique([mealEventId, employeeId])
}

model CheckinLog {
  id           String        @id @default(cuid())
  mealEventId  String
  employeeId   String?
  guestId      String?
  checkinTime  DateTime      @default(now())
  method       CheckinMethod
  employee     Employee?     @relation(fields: [employeeId], references: [id])
  guest        Guest?        @relation(fields: [guestId], references: [id])
  mealEvent    MealEvent     @relation(fields: [mealEventId], references: [id])
  registration Registration? @relation(fields: [mealEventId, employeeId], references: [mealEventId, employeeId])

  @@unique([mealEventId, employeeId])
  @@unique([mealEventId, guestId])
}

model Guest {
  id          String          @id @default(cuid())
  mealEventId String
  fullName    String          @db.VarChar(100)
  note        String?         @db.VarChar(255)
  qrToken     String          @unique
  phoneNumber String?         @db.VarChar(20)
  directoryId String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  checkins    CheckinLog[]
  mealEvent   MealEvent       @relation(fields: [mealEventId], references: [id])
  directory   GuestDirectory? @relation(fields: [directoryId], references: [id])
  creator     Employee?       @relation("GuestCreator", fields: [createdBy], references: [id])
}

model GuestDirectory {
  id        String   @id @default(cuid())
  fullName  String   @db.VarChar(100)
  phoneNumber String? @db.VarChar(20)
  note      String?  @db.VarChar(255)
  isActive  Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  guests    Guest[]
  creator   Employee? @relation("GuestDirectoryCreator", fields: [createdBy], references: [id])

  @@unique([fullName, phoneNumber])
}

model Ingredient {
  id          String            @id @default(cuid())
  mealEventId String
  catalogId   String
  quantity    Float
  unit        String           @db.VarChar(20)
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  catalog     IngredientCatalog @relation(fields: [catalogId], references: [id])
  mealEvent   MealEvent         @relation(fields: [mealEventId], references: [id])
}

model IngredientCatalog {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(100)
  defaultUnit String       @db.VarChar(20)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ingredients Ingredient[]
}

model MenuItem {
  id          String          @id @default(cuid())
  mealEventId String
  catalogId   String
  createdAt   DateTime        @default(now())
  catalog     MenuItemCatalog @relation(fields: [catalogId], references: [id])
  mealEvent   MealEvent       @relation(fields: [mealEventId], references: [id])
}

model MenuItemCatalog {
  id        String     @id @default(cuid())
  name      String     @unique @db.VarChar(100)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  menuItems MenuItem[]
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RegistrationPreset {
  id         String        @id @default(cuid())
  name       String        @unique
  mealType   String
  weekdays   String
  locationId String?
  location   MealLocation? @relation(fields: [locationId], references: [id])
}

model MealLocation {
  id                  String               @id @default(cuid())
  name                String               @unique @db.VarChar(50)
  isDefault           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  registrations       Registration[]
  registrationPresets RegistrationPreset[]
}

model MealReview {
  id           String    @id @default(cuid())
  mealEventId  String
  employeeId   String
  comment      String    @db.Text
  rating       Int       @default(5)
  isAnonymous  Boolean   @default(true)
  images       String[]
  adminReply   String?   @db.Text
  adminReplyAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id])
  mealEvent    MealEvent @relation(fields: [mealEventId], references: [id])
}

model MealPriceConfig {
  id        String    @id @default(cuid())
  price     Float
  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Role {
  EMPLOYEE
  ADMIN_KITCHEN
  ADMIN_SYSTEM
  HR
  CLERK
}

enum MealType {
  LUNCH
  DINNER
}

enum MealStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum CheckinMethod {
  QR_SCAN
  MANUAL
  SELF_SCAN
}
